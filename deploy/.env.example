MYSQL_ROOT_PASS=change_me_local_mysql_root_password
ADMIN_TOKEN=change_me_admin_token

# Company read-only source database.
# Fill these values in deploy/.env on the target machine.
SOURCE_DB_HOST=your_readonly_db_host
SOURCE_DB_PORT=3306
SOURCE_DB_USER=your_readonly_db_user
SOURCE_DB_PASS=your_readonly_db_password

MAX_DEVICE_LOGS=5000
INLINE_LOG_LIMIT=1000
CACHE_TTL_SECONDS=300
CACHE_DIR=/app/cache

AUTH_SECRET=change_me_random_auth_secret
SESSION_TTL_SECONDS=604800

# Format: username:password:role,username2:password2:role
# role can be admin or user.
ZHIKU_USERS=admin:change_me_admin_password:admin,user01:change_me_user_password:user
